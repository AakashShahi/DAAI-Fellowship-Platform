# Legacy filename — prefer .env.example. Copy to .env for local use.

APP_NAME=DAAI Fellowship Platform
APP_ENV=development
DEBUG=True

HOST=127.0.0.1
PORT=8000
uvicorn app.main:app --reloaduvicorn app.main:app --reload
# MongoDB Configuration
# For local MongoDB: mongodb://localhost:27017
# For MongoDB Atlas: mongodb+srv://USERNAME:PASSWORD@cluster0.example.mongodb.net/daai_fellowship?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=daai_fellowship
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# JWT Configuration
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=DAAI Fellowship
SMTP_USE_TLS=True
